<?xml version="1.0" encoding="UTF-8"?>
<qgis projectname="Advanced QGIS Heat Map" version="3.34.4-Prizren">
  <homePath path=""/>
  <title>Advanced Heat Map - {{ANALYSIS_DATE}}</title>
  <properties>
    <WMSServiceTitle type="QString">MMCD Advanced Vector Index Heat Map</WMSServiceTitle>
    <WMSServiceAbstract type="QString">Professional cartographic heat map with interpolation and advanced styling - {{SPECIES_LABEL}}</WMSServiceAbstract>
    <WMSExtent type="QgsRectangle">
      <xmin>-97.5</xmin>
      <ymin>43.0</ymin>
      <xmax>-89.5</xmax>
      <ymax>49.5</ymax>
    </WMSExtent>
    <WMSKeywordList>
      <value>heat map</value>
      <value>interpolation</value>
      <value>mosquito surveillance</value>
    </WMSKeywordList>
  </properties>
  
  <projectlayers>
    <!-- ADVANCED HEAT MAP with IDW Interpolation -->
    <maplayer>
      <id>advanced_heatmap</id>
      <datasource>{{GPKG_PATH}}|layername=sections_heatmap</datasource>
      <layername>Advanced Vector Index Heat Map</layername>
      <srs>
        <spatialrefsys>
          <proj4>+proj=longlat +datum=WGS84 +no_defs</proj4>
          <srsid>3452</srsid>
          <srid>4326</srid>
          <authid>EPSG:4326</authid>
          <description>WGS 84</description>
        </spatialrefsys>
      </srs>
      <provider encoding="UTF-8">ogr</provider>
      <!-- ADVANCED HEATMAP RENDERER with continuous interpolation -->
      <renderer-v2 type="heatmapRenderer" forceraster="0">
        <heatmapSettings>
          <radius>50000</radius>  <!-- 50km radius -->
          <radiusUnit>3</radiusUnit>  <!-- meters -->
          <weightExpression>vector_index</weightExpression>
          <maximumValue>0</maximumValue>
          <qualityLevel>0</qualityLevel>
          <renderQuality>0</renderQuality>
        </heatmapSettings>
        <colorramp type="gradient" name="[source]">
          <prop k="color1" v="255,255,204,0"/>  <!-- Transparent yellow -->
          <prop k="color2" v="161,218,180,255"/>  <!-- Light green -->
          <prop k="discrete" v="0"/>
          <prop k="rampType" v="gradient"/>
          <prop k="stops" v="0.25;65,182,196,255:0.5;34,94,168,255:0.75;8,29,88,255"/>
        </colorramp>
      </renderer-v2>
    </maplayer>
    
    <!-- CONTOUR LINES showing vector index isolines -->
    <maplayer>
      <id>vector_contours</id>
      <datasource>{{GPKG_PATH}}|layername=sections_heatmap</datasource>
      <layername>Vector Index Contours</layername>
      <srs>
        <spatialrefsys>
          <proj4>+proj=longlat +datum=WGS84 +no_defs</proj4>
          <srsid>3452</srsid>
          <srid>4326</srid>
          <authid>EPSG:4326</authid>
          <description>WGS 84</description>
        </spatialrefsys>
      </srs>
      <provider encoding="UTF-8">ogr</provider>
      <renderer-v2 type="categorizedSymbol" attr="CASE WHEN vector_index &lt; 10 THEN 'Low' WHEN vector_index &lt; 25 THEN 'Medium' WHEN vector_index &lt; 50 THEN 'High' ELSE 'Critical' END" symbollevels="0" forceraster="0">
        <categories>
          <category value="Low" label="Low Risk (0-10)" symbol="0" render="true"/>
          <category value="Medium" label="Medium Risk (10-25)" symbol="1" render="true"/>
          <category value="High" label="High Risk (25-50)" symbol="2" render="true"/>
          <category value="Critical" label="Critical (50+)" symbol="3" render="true"/>
        </categories>
        <symbols>
          <symbol alpha="1" type="marker" name="0" clip_to_extent="1" force_rhr="0">
            <layer class="SimpleMarker" locked="0" pass="0" enabled="1">
              <prop k="angle" v="0"/>
              <prop k="color" v="255,255,0,100"/>
              <prop k="size" v="8"/>
              <prop k="size_unit" v="Point"/>
              <prop k="outline_color" v="35,35,35,255"/>
              <prop k="outline_style" v="solid"/>
              <prop k="outline_width" v="0"/>
            </layer>
          </symbol>
          <symbol alpha="1" type="marker" name="1" clip_to_extent="1" force_rhr="0">
            <layer class="SimpleMarker" locked="0" pass="0" enabled="1">
              <prop k="angle" v="0"/>
              <prop k="color" v="255,165,0,150"/>
              <prop k="size" v="12"/>
              <prop k="size_unit" v="Point"/>
              <prop k="outline_color" v="35,35,35,255"/>
              <prop k="outline_style" v="solid"/>
              <prop k="outline_width" v="1"/>
            </layer>
          </symbol>
          <symbol alpha="1" type="marker" name="2" clip_to_extent="1" force_rhr="0">
            <layer class="SimpleMarker" locked="0" pass="0" enabled="1">
              <prop k="angle" v="0"/>
              <prop k="color" v="255,69,0,200"/>
              <prop k="size" v="16"/>
              <prop k="size_unit" v="Point"/>
              <prop k="outline_color" v="35,35,35,255"/>
              <prop k="outline_style" v="solid"/>
              <prop k="outline_width" v="2"/>
            </layer>
          </symbol>
          <symbol alpha="1" type="marker" name="3" clip_to_extent="1" force_rhr="0">
            <layer class="SimpleMarker" locked="0" pass="0" enabled="1">
              <prop k="angle" v="0"/>
              <prop k="color" v="139,0,0,255"/>
              <prop k="size" v="20"/>
              <prop k="size_unit" v="Point"/>
              <prop k="outline_color" v="255,255,255,255"/>
              <prop k="outline_style" v="solid"/>
              <prop k="outline_width" v="2"/>
            </layer>
          </symbol>
        </symbols>
      </renderer-v2>
    </maplayer>
    
    <!-- LABELED POINTS with dynamic text -->
    <maplayer>
      <id>section_labels</id>
      <datasource>{{GPKG_PATH}}|layername=sections_heatmap</datasource>
      <layername>Section Labels</layername>
      <srs>
        <spatialrefsys>
          <proj4>+proj=longlat +datum=WGS84 +no_defs</proj4>
          <srsid>3452</srsid>
          <srid>4326</srid>
          <authid>EPSG:4326</authid>
          <description>WGS 84</description>
        </spatialrefsys>
      </srs>
      <provider encoding="UTF-8">ogr</provider>
      <renderer-v2 type="nullSymbol"/>
      <labeling type="simple">
        <settings>
          <text-style fontFamily="Arial" fontSize="8" fontSizeUnit="Point" fontWeight="50" fontItalic="0" fontStrikeout="0" fontUnderline="0" textColor="0,0,0,255" previewBkgrdColor="255,255,255,255">
            <text-buffer bufferDraw="1" bufferSize="1" bufferSizeUnit="MM" bufferColor="255,255,255,255" bufferNoFill="0" bufferOpacity="1"/>
          </text-style>
          <text-format leftDirectionSymbol="&lt;" rightDirectionSymbol=">" reverseDirectionSymbol="0" wrapChar="" multilineAlign="0" placeDirectionSymbol="0" formatNumbers="0" decimals="3" plussign="0"/>
          <text-placement placement="0" placementFlags="10" quadOffset="4" xOffset="0" yOffset="0" offsetType="0" centroidWhole="0" centroidInside="0" predefinedPositionOrder="TR,TL,BR,BL,R,L,TSR,BSR"/>
          <rendering scaleVisibility="1" scaleMin="1" scaleMax="50000" fontLimitPixelSize="0" fontMinPixelSize="3" fontMaxPixelSize="10000" displayAll="0" upsidedownLabels="0" maxNumLabels="2000" obstacle="1" obstacleFactor="1" obstacleType="0" zIndex="0"/>
          <dd_properties>
            <Option type="Map">
              <Option type="QString" name="name" value=""/>
              <Option name="properties"/>
              <Option type="QString" name="type" value="collection"/>
            </Option>
          </dd_properties>
        </settings>
        <fieldName>CASE WHEN vector_index > 25 THEN round(vector_index, 1) ELSE '' END</fieldName>
        <isExpression>1</isExpression>
      </labeling>
    </maplayer>
    
    <!-- REFERENCE LAYERS -->
    <maplayer>
      <id>seven_counties</id>
      <datasource>/srv/shiny-server/shared/gpkg/7counties.gpkg</datasource>
      <layername>7 Counties Context</layername>
      <srs>
        <spatialrefsys>
          <proj4>+proj=longlat +datum=WGS84 +no_defs</proj4>
          <srsid>3452</srsid>
          <srid>4326</srid>
          <authid>EPSG:4326</authid>
          <description>WGS 84</description>
        </spatialrefsys>
      </srs>
      <provider encoding="UTF-8">ogr</provider>
      <renderer-v2 type="singleSymbol" symbollevels="0" forceraster="0">
        <symbols>
          <symbol alpha="1" type="fill" name="0" clip_to_extent="1" force_rhr="0">
            <layer class="SimpleFill" locked="0" pass="0" enabled="1">
              <prop k="border_width_map_unit_scale" v="3x:0,0,0,0,0,0"/>
              <prop k="color" v="0,0,0,0"/>
              <prop k="joinstyle" v="bevel"/>
              <prop k="offset" v="0,0"/>
              <prop k="offset_map_unit_scale" v="3x:0,0,0,0,0,0"/>
              <prop k="offset_unit" v="MM"/>
              <prop k="outline_color" v="80,80,80,255"/>
              <prop k="outline_style" v="solid"/>
              <prop k="outline_width" v="0.8"/>
              <prop k="outline_width_unit" v="Point"/>
              <prop k="style" v="no"/>
            </layer>
          </symbol>
        </symbols>
      </renderer-v2>
    </maplayer>
  </projectlayers>
  
  <layerorder>
    <layer id="seven_counties"/>
    <layer id="advanced_heatmap"/>
    <layer id="vector_contours"/>
    <layer id="section_labels"/>
  </layerorder>
  
  <legend updateDrawingOrder="true">
    <legendlayer drawingOrder="-1" open="true" checked="Qt::Checked" name="advanced_heatmap" showFeatureCount="0">
      <filegroup open="true" hidden="false">
        <legendlayerfile isInOverview="0" layerid="advanced_heatmap" visible="1"/>
      </filegroup>
    </legendlayer>
    <legendlayer drawingOrder="-1" open="true" checked="Qt::Checked" name="vector_contours" showFeatureCount="0">
      <filegroup open="true" hidden="false">
        <legendlayerfile isInOverview="0" layerid="vector_contours" visible="1"/>
      </filegroup>
    </legendlayer>
    <legendlayer drawingOrder="-1" open="false" checked="Qt::Checked" name="section_labels" showFeatureCount="0">
      <filegroup open="false" hidden="false">
        <legendlayerfile isInOverview="0" layerid="section_labels" visible="1"/>
      </filegroup>
    </legendlayer>
    <legendlayer drawingOrder="-1" open="false" checked="Qt::Checked" name="seven_counties" showFeatureCount="0">
      <filegroup open="false" hidden="false">
        <legendlayerfile isInOverview="0" layerid="seven_counties" visible="1"/>
      </filegroup>
    </legendlayer>
  </legend>
  
  <mapcanvas annotationsVisible="1" name="theMapCanvas">
    <units>degrees</units>
    <extent>
      <xmin>-97.5</xmin>
      <ymin>43.0</ymin>
      <xmax>-89.5</xmax>
      <ymax>49.5</ymax>
    </extent>
    <rotation>0</rotation>
    <destinationsrs>
      <spatialrefsys>
        <proj4>+proj=longlat +datum=WGS84 +no_defs</proj4>
        <srsid>3452</srsid>
        <srid>4326</srid>
        <authid>EPSG:4326</authid>
        <description>WGS 84</description>
      </spatialrefsys>
    </destinationsrs>
  </mapcanvas>
</qgis>