<!DOCTYPE qgis PUBLIC 'http://mrcc.com/qgis.dtd' 'SYSTEM'>
<qgis version="3.28.0" projectname="Dynamic Heat Map - {{ANALYSIS_DATE}}">
  <homePath path=""/>
  <title>Trap Surveillance Heat Map - {{SPECIES_LABEL}}</title>
  <projectCrs>
    <spatialrefsys>
      <proj4>+proj=longlat +datum=WGS84 +no_defs</proj4>
      <srsid>3452</srsid>
      <srid>4326</srid>
      <authid>EPSG:4326</authid>
      <description>WGS 84</description>
    </spatialrefsys>
  </projectCrs>
  
  <layer-tree-group>
    <customproperties/>
    
    <!-- Main Heat Map Layer -->
    <layer-tree-layer id="sections_heatmap" name="Simple Heat Map - {{ANALYSIS_DATE}}" checked="Qt::Checked" expanded="1" source="{{GPKG_PATH}}|layername=sections_heatmap" providerKey="ogr">
      <customproperties/>
    </layer-tree-layer>
    
    <!-- Reference Layers -->
    <layer-tree-layer id="seven_counties" name="7 Counties" checked="Qt::Checked" expanded="0" source="/srv/shiny-server/shared/gpkg/7counties.gpkg" providerKey="ogr">
      <customproperties/>
    </layer-tree-layer>
    
    <layer-tree-layer id="facility_areas" name="Facility Areas" checked="Qt::Unchecked" expanded="0" source="/srv/shiny-server/shared/gpkg/MMCD_FacilityArea.gpkg" providerKey="ogr">
      <customproperties/>
    </layer-tree-layer>
    
  </layer-tree-group>
  
  <projectlayers>
    
    <!-- Heat Map Layer with Graduated Symbology -->
    <maplayer type="vector" geometry="Point">
      <id>sections_heatmap</id>
      <datasource>{{GPKG_PATH}}|layername=sections_heatmap</datasource>
      <layername>Simple Heat Map - {{ANALYSIS_DATE}}</layername>
      <srs>
        <spatialrefsys>
          <proj4>+proj=longlat +datum=WGS84 +no_defs</proj4>
          <srsid>3452</srsid>
          <srid>4326</srid>
          <authid>EPSG:4326</authid>
          <description>WGS 84</description>
        </spatialrefsys>
      </srs>
      <provider encoding="UTF-8">ogr</provider>
      
      <!-- Graduated Symbol Renderer -->
      <renderer-v2 type="graduatedSymbol" attr="vector_index" graduatedMethod="GraduatedColor">
        <ranges>
          <range lower="0" upper="10" symbol="0" label="0 - 10 (Low)" render="true"/>
          <range lower="10" upper="25" symbol="1" label="10 - 25 (Medium)" render="true"/>
          <range lower="25" upper="50" symbol="2" label="25 - 50 (High)" render="true"/>
          <range lower="50" upper="99999" symbol="3" label="> 50 (Critical)" render="true"/>
        </ranges>
        <symbols>
          <symbol type="marker" name="0" alpha="0.8">
            <layer class="SimpleMarker">
              <prop k="color" v="255,255,100,204"/>
              <prop k="size" v="4"/>
              <prop k="outline_color" v="0,0,0,255"/>
              <prop k="outline_width" v="0.4"/>
            </layer>
          </symbol>
          <symbol type="marker" name="1" alpha="0.8">
            <layer class="SimpleMarker">
              <prop k="color" v="255,170,0,204"/>
              <prop k="size" v="6"/>
              <prop k="outline_color" v="0,0,0,255"/>
              <prop k="outline_width" v="0.4"/>
            </layer>
          </symbol>
          <symbol type="marker" name="2" alpha="0.8">
            <layer class="SimpleMarker">
              <prop k="color" v="255,85,0,204"/>
              <prop k="size" v="8"/>
              <prop k="outline_color" v="0,0,0,255"/>
              <prop k="outline_width" v="0.4"/>
            </layer>
          </symbol>
          <symbol type="marker" name="3" alpha="0.8">
            <layer class="SimpleMarker">
              <prop k="color" v="200,0,0,204"/>
              <prop k="size" v="12"/>
              <prop k="outline_color" v="0,0,0,255"/>
              <prop k="outline_width" v="0.6"/>
            </layer>
          </symbol>
        </symbols>
      </renderer-v2>
    </maplayer>
    
    <!-- 7 Counties Reference -->
    <maplayer type="vector" geometry="Polygon">
      <id>seven_counties</id>
      <datasource>/srv/shiny-server/shared/gpkg/7counties.gpkg</datasource>
      <layername>7 Counties</layername>
      <srs>
        <spatialrefsys>
          <proj4>+proj=longlat +datum=WGS84 +no_defs</proj4>
          <srsid>3452</srsid>
          <srid>4326</srid>
          <authid>EPSG:4326</authid>
          <description>WGS 84</description>
        </spatialrefsys>
      </srs>
      <provider encoding="UTF-8">ogr</provider>
      <renderer-v2 type="singleSymbol">
        <symbols>
          <symbol type="fill" name="0" alpha="0">
            <layer class="SimpleFill">
              <prop k="color" v="0,0,0,0"/>
              <prop k="outline_color" v="80,80,80,255"/>
              <prop k="outline_width" v="0.8"/>
              <prop k="style" v="no"/>
            </layer>
          </symbol>
        </symbols>
      </renderer-v2>
    </maplayer>
    
    <!-- Facility Areas Reference -->
    <maplayer type="vector" geometry="Polygon">
      <id>facility_areas</id>
      <datasource>/srv/shiny-server/shared/gpkg/MMCD_FacilityArea.gpkg</datasource>
      <layername>Facility Areas</layername>
      <srs>
        <spatialrefsys>
          <proj4>+proj=longlat +datum=WGS84 +no_defs</proj4>
          <srsid>3452</srsid>
          <srid>4326</srid>
          <authid>EPSG:4326</authid>
          <description>WGS 84</description>
        </spatialrefsys>
      </srs>
      <provider encoding="UTF-8">ogr</provider>
      <renderer-v2 type="singleSymbol">
        <symbols>
          <symbol type="fill" name="0" alpha="0">
            <layer class="SimpleFill">
              <prop k="color" v="0,0,0,0"/>
              <prop k="outline_color" v="60,60,200,255"/>
              <prop k="outline_width" v="0.6"/>
              <prop k="style" v="no"/>
            </layer>
          </symbol>
        </symbols>
      </renderer-v2>
    </maplayer>
    
  </projectlayers>
  
  <layerorder>
    <layer id="sections_heatmap"/>
    <layer id="seven_counties"/>
    <layer id="facility_areas"/>
  </layerorder>
  
  <mapcanvas>
    <units>degrees</units>
    <extent>
      <xmin>-94.5</xmin>
      <ymin>44.0</ymin>
      <xmax>-92.5</xmax>
      <ymax>46.0</ymax>
    </extent>
    <destinationsrs>
      <spatialrefsys>
        <proj4>+proj=longlat +datum=WGS84 +no_defs</proj4>
        <srsid>3452</srsid>
        <srid>4326</srid>
        <authid>EPSG:4326</authid>
        <description>WGS 84</description>
      </spatialrefsys>
    </destinationsrs>
  </mapcanvas>
  
</qgis>
